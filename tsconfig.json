{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,

    // Bundler mode
    "moduleResolution": "bundler",
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./",
    "declaration": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,

    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*", "./webview-ui/src/*"],
      "@shared/*": ["./src/shared/*", "./webview-ui/src/shared/*"],
      "@core/*": ["./src/core/*", "./webview-ui/src/core/*"],
      "@infrastructure/*": ["./src/infrastructure/*"],
      "@domain/*": ["./src/domain/*"],
      "@ui/*": ["./src/ui/*"],
      "@integrations/*": ["./webview-ui/src/integrations/*"],
      "@services/*": ["./webview-ui/src/services/*"],
      "@hosts/*": ["./webview-ui/src/hosts/*"],
      "@utils/*": ["./webview-ui/src/utils/*"],
      "@registry": ["./webview-ui/src/registry"]
    }
  },
  "exclude": ["webview-ui", "dist", "node_modules"]
}

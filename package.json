{
  "name": "dietcode",
  "publisher": "dietcode",
  "version": "2.7.6",
  "icon": "assets/vsix/extension-icon.png",
  "type": "module",
  "private": true,
  "description": "Sovereign Hive Architecture for DietCode - Zero-Shim AI Orchestration",
  "repository": "https://github.com/CardSorting/DietCode",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dietcode-explorer",
          "title": "DietCode",
          "icon": "assets/vsix/activity-bar.svg"
        }
      ]
    },
    "views": {
      "dietcode-explorer": [
        {
          "type": "webview",
          "id": "dietcode-webview",
          "name": "Sovereign Hive",
          "icon": "assets/vsix/activity-bar.svg",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "dietcode.openWebView",
        "title": "DietCode: Open Sovereign Hive"
      }
    ]
  },
  "scripts": {
    "build:webview": "cd $(pwd)/webview-ui && npm run build",
    "build:cli": "bun build ./index.ts --outfile=./dist/index.js --target=node --external better-sqlite3 --external @noorm/broccoliq",
    "build:extension": "bun build ./src/extension.ts --outfile=./dist/extension.js --target=node --external vscode",
    "rebuild:electron": "./node_modules/.bin/electron-rebuild --version 39.0.0 --only better-sqlite3",
    "sync:native": "bun ./scripts/sync_native_modules.ts",
    "build": "npm run build:webview && npm run build:cli && npm run build:extension && npm run rebuild:electron && npm run sync:native",
    "dev": "tsc --watch",
    "cli": "node ./dist/index.js",
    "cli:dev": "node ./index.ts",
    "link": "npm link",
    "postinstall": "npm run build:cli && npm run link",
    "test": "vitest run",
    "lint": "biome lint . && eslint .",
    "format": "biome format . --write",
    "check": "biome check --apply .",
    "verify": "npx tsx verify_advanced_infrastructure.ts",
    "package:vsix": "./node_modules/.bin/vsce package"
  },
  "bin": {
    "dietcode": "./dist/index.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@noorm/broccoliq": "^2.3.0",
    "better-sqlite3": "^12.8.0",
    "kysely": "^0.28.2",
    "kysely-bun-sqlite": "^0.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.3",
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^9.10.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.2",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.7.1",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "eslint": "^9.10.0",
    "eslint-config-prettier": "^9.1.0",
    "globby": "^16.2.0",
    "grpc-tools": "^1.13.1",
    "ts-proto": "^2.11.6",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.5.0",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "better-sqlite3": "^12.8.0"
  },
  "license": "MIT"
}

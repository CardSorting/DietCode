{
  "name": "dietcode",
  "version": "2.0.0",
  "type": "module",
  "private": true,
  "description": "Sovereign Hive Architecture for DietCode - Zero-Shim AI Orchestration",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "bun build ./index.ts --outfile=./dist/index.js --target=node --bundle --external better-sqlite3 --external bindings",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "biome lint . && eslint .",
    "format": "biome format . --write",
    "check": "biome check --apply .",
    "verify": "npx tsx verify_advanced_infrastructure.ts"
  },
  "bin": {
    "dietcode": "./dist/index.js"
  },
  "dependencies": {
    "@noorm/broccoliq": "^2.2.5",
    "@anthropic-ai/sdk": "^0.82.0",
    "better-sqlite3": "^11.3.0",
    "kysely": "^0.28.2",
    "kysely-bun-sqlite": "^0.4.0",
    "openai": "^6.33.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.3",
    "@eslint/js": "^9.10.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.2",
    "chokidar": "^5.0.0",
    "eslint": "^9.10.0",
    "eslint-config-prettier": "^9.1.0",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.5.0",
    "vitest": "^3.2.4"
  },
  "license": "MIT"
}

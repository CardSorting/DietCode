# Sovereign Hive Insulation Guard (.npmignore)
# This file is a fallback for the 'files' field in package.json.
# It ensures no source leakage occurs in the event of an NPM misconfiguration.

# 1. Source Protection
src/
test/
scripts/
docs/
INFRASTRUCTURE/
.dietcode/
.cursor/

# 2. Local Environment
node_modules/
.git/
.gitignore
bun.lock
package-lock.json
tsconfig.json
CLAUDE.md
*.md

# 3. Development Artifacts
*.db*
dist/**/*.ts
dist/**/*.map
verify_*.ts
test_*.ts
npx_*.ts
index.ts

# 4. Sovereign Exclusions
# Only 'dist/', 'README.md', 'LICENSE', and conduct/security docs 
# are allowed into the distribution tarball.

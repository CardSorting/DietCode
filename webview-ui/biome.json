{
  "organizeImports": {
    "enabled": false
  },
  "linter": {
    "enabled": true
  },
  "formatter": {
    "enabled": false,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 100
  },
  "files": {
    "ignore": [
      "dist",
      "build",
      "node_modules",
      "**/*.test.ts",
      "**/*.spec.ts",
      "**/__tests__/**",
      "**/cline-main/**",
      "**/nice-grpc/**",
      "**/proto/**"
    ]
  },
  "javascript": {
    "formatter": {
      "enabled": true
    }
  },
  "json": {
    "formatter": {
      "enabled": true
    }
  },
  "css": {
    "formatter": {
      "enabled": true
    }
  }
}